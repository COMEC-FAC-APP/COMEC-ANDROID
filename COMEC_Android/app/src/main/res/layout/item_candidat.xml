<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@color/white"
    android:layout_marginBottom="2dp" android:padding="10dp">
    <TextView android:id="@+id/tv_rank" android:layout_width="36dp" android:layout_height="wrap_content"
        android:textColor="@color/green_primary" android:textSize="12sp" android:textStyle="bold"/>
    <TextView android:id="@+id/tv_name" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="@color/text_dark" android:textSize="13sp"/>
    <TextView android:id="@+id/tv_note" android:layout_width="40dp" android:layout_height="wrap_content"
        android:textColor="@color/text_dark" android:textSize="13sp" android:textStyle="bold" android:gravity="center"/>
    <TextView android:id="@+id/tv_mention" android:layout_width="30dp" android:layout_height="wrap_content"
        android:textColor="@color/green_primary" android:textSize="12sp" android:textStyle="bold" android:gravity="center"/>
</LinearLayout>
