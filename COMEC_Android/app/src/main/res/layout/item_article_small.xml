<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@color/white"
    android:layout_marginBottom="8dp" android:padding="10dp" android:elevation="1dp">
    <TextView android:id="@+id/tv_emoji" android:layout_width="36dp" android:layout_height="36dp" android:textSize="20sp" android:gravity="center"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
        <TextView android:id="@+id/tv_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_dark" android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_category" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/text_muted" android:textSize="11sp"/>
        <TextView android:id="@+id/tv_excerpt" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#4a5e4d" android:textSize="12sp" android:maxLines="2" android:ellipsize="end"/>
    </LinearLayout>
</LinearLayout>
