<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="@color/white"
    android:layout_marginBottom="4dp" android:padding="10dp">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_item_title" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_dark" android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_item_sub" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_muted" android:textSize="11sp"/>
    </LinearLayout>
    <Button android:id="@+id/btn_delete" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="X" android:textColor="@color/white" android:background="@color/red"
        android:textSize="11sp" android:paddingHorizontal="12dp" android:paddingVertical="4dp"/>
</LinearLayout>
