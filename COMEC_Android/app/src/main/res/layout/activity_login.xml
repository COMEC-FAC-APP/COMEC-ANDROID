<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:background="@color/green_dark" android:padding="32dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="COMEC" android:textColor="@color/white" android:textSize="36sp" android:textStyle="bold"
        android:letterSpacing="0.2" android:layout_marginBottom="4dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="ADMINISTRATION" android:textColor="@color/yellow" android:textSize="11sp"
        android:letterSpacing="0.15" android:layout_marginBottom="32dp"/>

    <EditText android:id="@+id/et_username"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Identifiant" android:inputType="text"
        android:background="@color/white" android:padding="14dp" android:layout_marginBottom="12dp"
        android:textSize="15sp"/>

    <EditText android:id="@+id/et_password"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Mot de passe" android:inputType="textPassword"
        android:background="@color/white" android:padding="14dp" android:layout_marginBottom="8dp"
        android:textSize="15sp"/>

    <TextView android:id="@+id/tv_error"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/yellow" android:textSize="12sp" android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btn_login"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="CONNEXION" android:background="@color/green_primary"
        android:textColor="@color/white" android:textSize="15sp" android:padding="14dp"/>
</LinearLayout>
